<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/styles.css">
  <title>Welcome to Oauth2.0-project| Login</title>
</head>
<body>

   <nav>
    <ul>
      <li><a href="/">Home</a></li>
     <% if (!user) { %>
    <li><a href="/auth/login">Login</a></li>
<% } else { %>
    <li><a href="/auth/logout">Logout</a></li>
    <li><a href="/profile">Profile</a></li>
<% } %>
    </ul>
  </nav>

  <div class="container">
    <h1>Welcome to Oauth2.0-project| Login</h1>

    <% if (user) { %>
      <p>You are already logged in as <%= user.displayName || user.username %></p>
    <% } else { %>
      <a href="/auth/google">Login with Google</a>
    <% } %>

  </div>

</body>
</html>
