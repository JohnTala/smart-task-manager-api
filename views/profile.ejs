<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Profile | <%= user ? user.username : 'Guest' %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<nav>
  <ul>
    <li><a href="/">Home</a></li>
    <% if (!user) { %>
      <li><a href="/auth/login">Login</a></li>
    <% } else { %>
      <li><a href="/auth/logout">Logout</a></li>
    <% } %>
    <li><a href="/profile">Profile</a></li>
  </ul>
</nav>

<div class="container">

<% if (user) { %>

  <h1>Welcome, <%= user.username %></h1>

  <% if (user.photoUrl) { %>
    <img src="<%= user.photoUrl %>" alt="User profile picture" width="100">
  <% } %>

  <hr>

  <h2>Your Tasks</h2>
  <% if (tasks && tasks.length > 0) { %>
    <% tasks.forEach(task => { %>
      <div>
        <strong><%= task.title %></strong>
        <p><%= task.description %></p>
      </div>
    <% }) %>
  <% } else { %>
    <p>No tasks available</p>
  <% } %>

  <hr>

  <h2>Your Comments</h2>
  <% if (comments && comments.length > 0) { %>
    <% comments.forEach(comment => { %>
      <div>
        <p><%= comment.text %></p>
        <small>Task: <%= comment.task ? comment.task.title : 'N/A' %></small>
      </div>
    <% }) %>
  <% } else { %>
    <p>No comments available</p>
  <% } %>

<% } else { %>

  <p>Please <a href="/auth/login">login</a> to view your profile.</p>

<% } %>

</div>

</body>
</html>
